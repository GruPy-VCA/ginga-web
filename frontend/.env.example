# Origem da API só (sem /api/v1 no final). Ex.: http://localhost:8000 ou https://xxxx.lambda-url.us-east-1.on.aws
VITE_API_BASE_URL=http://localhost:8000

# Região AWS do Cognito
VITE_AWS_REGION=us-east-1

# User Pool e App Client (mesmos valores de COGNITO_* / outputs Terraform ginga_cognito_*)
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
